{
  "manifest_version": 3,
  "name": "GitHub Repository Alphabetizer",
  "version": "1.0.0",
  "description": "Sorts your GitHub repositories on the home/dashboard page in alphabetical order.",
  "browser_specific_settings": {
    "gecko": {
      "id": "github-repo-alphabetizer@local",
      "data_collection_permissions": {
        "required": ["none"]
      }
    }
  },
  "content_scripts": [
    {
      "matches": ["https://github.com/*"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ]
}
